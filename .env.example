# ==============================
# Discord Selfbot Configuration
# ==============================

# Token akun Discord kamu (bukan bot token)
# Cara dapat: Developer Tools > Network > request apapun > Header "Authorization"
DISCORD_TOKEN=your_discord_token_here

# Prefix command (default: ?)
PREFIX=?

# ID akun kamu (untuk DM output)
# Klik kanan nama kamu > Copy ID (aktifkan Developer Mode dulu)
OWNER_ID=your_user_id_here

# Genius API Key untuk lirik (opsional)
# Daftar di https://genius.com/api-clients
GENIUS_API_KEY=

# Volume default (1-100)
DEFAULT_VOLUME=50

# Bahasa log (id / en)
LANG=id
